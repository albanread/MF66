endp()

; ── two-argument: ( F: a b -- g(a,b) )  a→d0, b→d1; pop one FP cell ──────────
proc(f_pow_word)
    str     x0, [DSP, #-cell]!
    ldr     d0, [FSP], #cell            ; d0 = a (FNOS), pop FP
    fmov    d1, FTOS                     ; d1 = b
    aapcs_call(rt_fpow)
    fmov    FTOS, d0
    ldr     x0, [DSP], #cell
    next()
endp()
proc(fatan2_word)
    str     x0, [DSP, #-cell]!
    ldr     d0, [FSP], #cell
    fmov    d1, FTOS
    aapcs_call(rt_fatan2)
    fmov    FTOS, d0
    ldr     x0, [DSP], #cell
    next()
endp()
