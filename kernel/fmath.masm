; MF66 kernel — transcendental floating-point words (AArch64 port of WF66's
; kernel/fmath.masm). Each calls a host libm wrapper via aapcs_call: the FP
; argument(s) go in d0 (and d1), the result comes back in d0. FTOS=d8 is callee-
; saved so it survives the call; the data TOS (x0) is caller-saved, so it is
; spilled/restored around the call. (Written out per-word: JASM macros don't
; substitute a parameter into a nested macro call like aapcs_call.)

; ── one-argument: ( F: r -- f(r) ) ──────────────────────────────────────────
proc(fsin_word)
    str     x0, [DSP, #-cell]!
    fmov    d0, FTOS
    aapcs_call(rt_fsin)
    fmov    FTOS, d0
    ldr     x0, [DSP], #cell
    next()
endp()
proc(fcos_word)
    str     x0, [DSP, #-cell]!
    fmov    d0, FTOS
    aapcs_call(rt_fcos)
    fmov    FTOS, d0
    ldr     x0, [DSP], #cell
    next()
endp()
